# GiassAi API server — environment variables (local dev)
# Copy this file to `.env` and fill in the secret values.
# `.env` is gitignored. On Railway these are set in the service Variables tab.

# --- Supabase (REQUIRED — server throws on startup if any is missing) ---
# URL and ANON key are public (also baked into the web app).
SUPABASE_URL=https://kqguyjsuctjjocljwwfy.supabase.co
SUPABASE_ANON_KEY=
# SECRET — get it from Railway (Variables) or Supabase dashboard:
# Project Settings -> API -> Project API keys -> service_role
SUPABASE_SERVICE_ROLE_KEY=

# --- AI providers (OPTIONAL) ---
# With no ANTHROPIC_API_KEY the AI runs in offline DEMO mode on sample data.
# Set GIASSAI_DEMO=1 to force demo mode even if a key is present.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GIASSAI_DEMO=1

# --- Database (REQUIRED — lib/db throws at startup if missing) ---
# Supabase Postgres connection string (URI). On Railway: Variables -> DATABASE_URL.
# Supabase dashboard: Project Settings -> Database -> Connection string -> URI.
DATABASE_URL=

# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
